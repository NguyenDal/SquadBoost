generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                  String               @id @default(cuid())
  email               String               @unique
  passwordHash        String
  role                UserRole             @default(CUSTOMER)
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  orders              Order[]
  passwordResetTokens PasswordResetToken[]
  profile             Profile?
}

model Profile {
  id          String   @id @default(cuid())
  userId      String   @unique
  displayName String?
  bio         String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Service {
  id          String   @id @default(cuid())
  title       String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  orders      Order[]
}

model Order {
  id         String @id @default(cuid())
  customerId String
  serviceId  String

  boostType      String
  currentRank    String?
  desiredRank    String?
  currentLP      String?
  peakRank       String?
  desiredWins    Int?
  placementGames Int?
  preferredRole  String?
  numberOfGames  Int?
  region         String?
  queueType      String?
  playMode       String?

  priorityOrder     Boolean @default(false)
  duoWithBooster    Boolean @default(false)
  liveStream        Boolean @default(false)
  appearOffline     Boolean @default(false)
  championsRoles    Boolean @default(false)
  bonusWin          Boolean @default(false)
  soloOnly          Boolean @default(false)
  undercoverWinrate Boolean @default(false)
  moderateKDA       Boolean @default(false)
  highMMRDuo        Boolean @default(false)

  basePrice  Float @default(0)
  addonPrice Float @default(0)
  totalPrice Float @default(0)

  notes     String?
  status    OrderStatus @default(PENDING)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  customer User    @relation(fields: [customerId], references: [id], onDelete: Cascade)
  service  Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  tokenHash String    @unique
  userId    String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum UserRole {
  CUSTOMER
  PROVIDER
  ADMIN
}

enum OrderStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELLED
}
